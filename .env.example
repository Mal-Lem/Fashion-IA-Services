# ══════════════════════════════════════════════════════
# Fashion AI Platform — Variables d'environnement
# Copiez ce fichier en apps/api/.env et remplissez les valeurs
# NE JAMAIS committer apps/api/.env dans Git
# ══════════════════════════════════════════════════════

# ── Application ──────────────────────────────────────
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# ── Base de données PostgreSQL ───────────────────────
DATABASE_URL=postgresql://fap_user:fap_password@localhost:5432/fap_dev

# ── Redis ────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=fap_redis_password

# ── JWT ─────────────────────────────────────────────
# Générer avec : openssl rand -hex 32
JWT_SECRET=dev-secret-change-in-production

# ── Google AI (Gemini) — Génération d'images ─────────
# Obtenir une clé : https://aistudio.google.com/apikey
GOOGLE_AI_API_KEY=your_gemini_api_key_here

# ── MinIO (Stockage d'images local) ──────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=fap_minio_user
MINIO_SECRET_KEY=fap_minio_password

# ── Email / SMTP (Mailpit en dev) ───────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=

# ── Pseudonymisation ──────────────────────────────────
# CRITIQUE : changer cette valeur en production !
# Générer avec : openssl rand -hex 32
PSEUDONYMIZATION_SALT=dev-salt-change-in-production

# ── GCP Pub/Sub (optionnel, dev = logs locaux) ───────
PUBSUB_TOPIC=fap-events

# ══════════════════════════════════════════════════════
# Variables prévues pour futures features (optionnelles)
# ══════════════════════════════════════════════════════
# STRIPE_SECRET_KEY=sk_test_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
# GOOGLE_CLIENT_ID=xxx
# GOOGLE_CLIENT_SECRET=xxx
# FACEBOOK_CLIENT_ID=xxx
# FACEBOOK_CLIENT_SECRET=xxx
