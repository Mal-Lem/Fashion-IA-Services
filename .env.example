# ══════════════════════════════════════════════════════
# Fashion AI Platform — Variables d'environnement
# Copiez ce fichier en .env.local et remplissez les valeurs
# NE JAMAIS committer .env.local dans Git
# ══════════════════════════════════════════════════════

# ── Application ──────────────────────────────────────
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# ── Base de données PostgreSQL ───────────────────────
# Format : postgresql://user:password@host:port/database
DATABASE_URL=postgresql://fap_user:fap_password@localhost:5432/fap_dev

# ── Redis ────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=fap_redis_password

# ── JWT (RS256) ───────────────────────────────────────
# Génération des clés :
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
# Puis mettre le contenu en une ligne avec \n
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# ── Storage (MinIO local en dev, Scaleway en prod) ───
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=fap_minio_user
STORAGE_SECRET_KEY=fap_minio_password
STORAGE_BUCKET_DESIGNS=fap-designs
STORAGE_BUCKET_PORTFOLIOS=fap-portfolios
STORAGE_CDN_URL=http://localhost:9000

# ── IA — Replicate (génération images) ───────────────
REPLICATE_API_KEY=r8_xxxxxxxxxxxxxxxxxxxx
REPLICATE_MODEL=stability-ai/stable-diffusion-xl-base-1.0
# Modèle fine-tuné (disponible après fine-tuning)
# REPLICATE_FINE_TUNED_MODEL=your-username/fashion-ai-v1

# ── GCP — Pub/Sub & BigQuery ──────────────────────────
# En développement : laisser vide pour logger localement
GCP_PROJECT_ID=fashion-ai-platform
PUBSUB_TOPIC=fap-events
# Chemin vers le fichier de compte de service GCP
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# Ou contenu JSON inline :
# GCP_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# ── Pseudonymisation ──────────────────────────────────
# CRITIQUE : changer cette valeur en production !
# Générer avec : openssl rand -hex 32
PSEUDONYMIZATION_SALT=dev-salt-change-this-in-production-immediately

# ── Stripe ────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_PREMIUM_MONTHLY=price_xxxxxxxxxxxx
STRIPE_PRICE_PREMIUM_YEARLY=price_xxxxxxxxxxxx
STRIPE_PRICE_PRO_MONTHLY=price_xxxxxxxxxxxx
STRIPE_PRICE_PRO_YEARLY=price_xxxxxxxxxxxx

# ── Email (Brevo / Mailpit en dev) ───────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@fashionai.fr
EMAIL_FROM_NAME=Fashion AI Platform

# ── Feature Flags ────────────────────────────────────
FEATURE_PUBSUB_ENABLED=false    # Activer en production
FEATURE_FINE_TUNING_ENABLED=false
FEATURE_OAUTH_GOOGLE=false
