generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

enum UserRole {
  user
  couturiere
  admin
}

enum UserStatus {
  active
  suspended
  pending_deletion
}

enum SubscriptionStatus {
  free
  trial
  premium
  pro
}

enum AvailabilityStatus {
  available
  busy
  on_request
}

enum DesignStatus {
  draft
  sent
  in_progress
  completed
}

enum GenerationMode {
  guided
  free_prompt
}

enum OrderStatus {
  pending
  accepted
  in_progress
  completed
  cancelled
  refused
}

enum PayoutStatus {
  pending
  processing
  paid
  failed
}

enum MessageType {
  text
  image
  system
}

model User {
  id                     String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email                  String             @unique @db.VarChar(255)
  passwordHash           String?            @map("password_hash") @db.VarChar(255)
  firstName              String             @map("first_name") @db.VarChar(100)
  lastName               String             @map("last_name") @db.VarChar(100)
  role                   UserRole           @default(user)
  status                 UserStatus         @default(active)
  emailVerified          Boolean            @default(false) @map("email_verified")
  oauthProvider          String?            @map("oauth_provider") @db.VarChar(50)
  oauthId                String?            @map("oauth_id") @db.VarChar(255)
  gender                 String?            @map("gender") @db.VarChar(20)
  morphologyJson         Json               @default("{}") @map("morphology_json")
  avatarUrl              String?            @map("avatar_url")
  locationZip            String?            @map("location_zip") @db.VarChar(10)
  preferencesJson        Json               @default("{}") @map("preferences_json")
  subscriptionStatus     SubscriptionStatus @default(free) @map("subscription_status")
  subscriptionExpiresAt  DateTime?          @map("subscription_expires_at") @db.Timestamptz
  aiCredits              Int                @default(0) @map("ai_credits")
  monthlyGenerationsUsed Int                @default(0) @map("monthly_generations_used")
  monthlyResetAt         DateTime           @map("monthly_reset_at") @db.Timestamptz
  stripeCustomerId       String?            @unique @map("stripe_customer_id") @db.VarChar(255)
  deletionRequestedAt    DateTime?          @map("deletion_requested_at") @db.Timestamptz
  createdAt              DateTime           @default(now()) @map("created_at") @db.Timestamptz
  updatedAt              DateTime           @updatedAt @map("updated_at") @db.Timestamptz
  verificationCode       String?            @map("verification_code")
  verificationExpiresAt  DateTime?          @map("verification_expires_at")

  passwordResetTokens PasswordResetToken[]
  
  couturiereProfile CouturiereProfile?
  designs           Design[]
  clientOrders      Order[]            @relation("ClientOrders")
  sentMessages      Message[]
  reviews           Review[]           @relation("ReviewerRelation")
  receivedReviews   Review[]           @relation("RevieweeRelation")
  events            Event[]
  refreshTokens     RefreshToken[]

  @@index([email])
  @@index([role])
  @@index([status])
  @@map("users")
}

model RefreshToken {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @map("token_hash") @db.VarChar(255)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}

model CouturiereProfile {
  id                   String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId               String             @unique @map("user_id") @db.Uuid
  atelierName          String             @map("atelier_name") @db.VarChar(200)
  bio                  String?
  siret                String?            @db.VarChar(14)
  specialties          String[]
  experienceYears      Int?               @map("experience_years")
  locationCity         String             @map("location_city") @db.VarChar(100)
  locationRegion       String             @map("location_region") @db.VarChar(100)
  locationZip          String             @map("location_zip") @db.VarChar(10)
  locationLat          Float?             @map("location_lat")
  locationLng          Float?             @map("location_lng")
  serviceRadiusKm      Int                @default(50) @map("service_radius_km")
  pricingMin           Int?               @map("pricing_min")
  pricingMax           Int?               @map("pricing_max")
  pricingHourly        Int?               @map("pricing_hourly")
  languages            String[]           @default(["fr"])
  availabilityStatus   AvailabilityStatus @default(available) @map("availability_status")
  profileCompletionPct Int                @default(0) @map("profile_completion_pct")
  isCertified          Boolean            @default(false) @map("is_certified")
  isVisible            Boolean            @default(false) @map("is_visible")
  avgRating            Decimal?           @map("avg_rating") @db.Decimal(3, 2)
  reviewCount          Int                @default(0) @map("review_count")
  responseRate         Decimal            @default(0) @map("response_rate") @db.Decimal(5, 2)
  portfolioPhotos      Json               @default("[]") @map("portfolio_photos")
  createdAt            DateTime           @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime           @updatedAt @map("updated_at") @db.Timestamptz

  user             User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  couturiereOrders Order[] @relation("CouturiereOrders")

  @@index([locationRegion])
  @@index([isVisible])
  @@index([availabilityStatus])
  @@map("couturiere_profiles")
}

model Design {
  id                   String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId               String         @map("user_id") @db.Uuid
  name                 String         @default("Mon design") @db.VarChar(100)
  status               DesignStatus   @default(draft)
  generationMode       GenerationMode @map("generation_mode")
  promptJson           Json           @map("prompt_json")
  freePrompt           String?        @map("free_prompt")
  generatedImages      String[]       @map("generated_images")
  selectedImageUrl     String?        @map("selected_image_url")
  thumbnailUrl         String?        @map("thumbnail_url")
  aiModelVersion       String         @map("ai_model_version") @db.VarChar(50)
  generationDurationMs Int?           @map("generation_duration_ms")
  userRating           Int?           @map("user_rating")
  isTrainingEligible   Boolean        @default(false) @map("is_training_eligible")
  expiresAt            DateTime       @map("expires_at") @db.Timestamptz
  isSaved              Boolean        @default(false) @map("is_saved")
  createdAt            DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime       @updatedAt @map("updated_at") @db.Timestamptz

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  @@index([userId])
  @@index([status])
  @@index([isSaved])
  @@map("designs")
}

model Order {
  id                    String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  designId              String       @map("design_id") @db.Uuid
  clientId              String       @map("client_id") @db.Uuid
  couturiereId          String       @map("couturiere_id") @db.Uuid
  status                OrderStatus  @default(pending)
  clientMessage         String?      @map("client_message")
  couturiereMessage     String?      @map("couturiere_message")
  refusalReason         String?      @map("refusal_reason") @db.VarChar(200)
  agreedAmount          Int?         @map("agreed_amount")
  commissionAmount      Int?         @map("commission_amount")
  netAmount             Int?         @map("net_amount")
  stripePaymentIntentId String?      @map("stripe_payment_intent_id") @db.VarChar(255)
  payoutStatus          PayoutStatus @default(pending) @map("payout_status")
  payoutAt              DateTime?    @map("payout_at") @db.Timestamptz
  completedAt           DateTime?    @map("completed_at") @db.Timestamptz
  createdAt             DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime     @updatedAt @map("updated_at") @db.Timestamptz

  design     Design            @relation(fields: [designId], references: [id])
  client     User              @relation("ClientOrders", fields: [clientId], references: [id])
  couturiere CouturiereProfile @relation("CouturiereOrders", fields: [couturiereId], references: [id])
  messages   Message[]
  review     Review?

  @@index([clientId])
  @@index([couturiereId])
  @@index([status])
  @@map("orders")
}

model Message {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId       String      @map("order_id") @db.Uuid
  senderId      String      @map("sender_id") @db.Uuid
  messageType   MessageType @default(text) @map("message_type")
  content       String?
  attachmentUrls String[]   @map("attachment_urls")
  isSystem      Boolean     @default(false) @map("is_system")
  readAt        DateTime?   @map("read_at") @db.Timestamptz
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamptz

  order  Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  sender User  @relation(fields: [senderId], references: [id])

  @@index([orderId])
  @@map("messages")
}

model Review {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId         String    @unique @map("order_id") @db.Uuid
  reviewerId      String    @map("reviewer_id") @db.Uuid
  revieweeId      String    @map("reviewee_id") @db.Uuid
  rating          Int
  comment         String?
  photoUrl        String?   @map("photo_url")
  couturiereReply String?   @map("couturiere_reply")
  replyAt         DateTime? @map("reply_at") @db.Timestamptz
  isFlagged       Boolean   @default(false) @map("is_flagged")
  isVisible       Boolean   @default(true) @map("is_visible")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz
 
  order    Order @relation(fields: [orderId], references: [id])
  reviewer User  @relation("ReviewerRelation", fields: [reviewerId], references: [id])
  reviewee User  @relation("RevieweeRelation", fields: [revieweeId], references: [id])
  isApprovedForHome Boolean @default(false) @map("is_approved_for_home")
  @@index([revieweeId])
  @@map("reviews")
}
model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}
  

model Event {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventType String   @map("event_type") @db.VarChar(100)
  userId    String?  @map("user_id") @db.Uuid
  sessionId String?  @map("session_id") @db.Uuid
  payload   Json     @default("{}")
  ipAddress String?  @map("ip_address") @db.VarChar(45)
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([eventType])
  @@index([userId])
  @@map("events")
}
